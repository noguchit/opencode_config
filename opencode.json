{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode@3.5.3"
  ],
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow"
  },
  "provider": {
    "reallms": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "RealLMS",
      "options": {
        "baseURL": "https://reallms.rescloud.iu.edu/direct/v1/",
        "apiKey": "{env:REALLMS_API_KEY}"
      },
      "models": {
        "llama-4-scout": {
          "name": "Llama 4 Scout (Focused Reasoning/Debugging)"
        },
        "DeepSeek-R1": {
          "name": "DeepSeek R1"
        },
        "Qwen3-Coder-Next": {
          "name": "Qwen3 Coder Next"
        },
        "Qwen3-Embedding-8B": {
          "name": "Qwen3 Embedding 8B"
        },
        "Qwen3-Reranker-8B": {
          "name": "Qwen3 Reranker 8B"
        },
        "embeddinggemma-300m": {
          "name": "Embedding Gemma 300M"
        },
        "gpt-oss-120b": {
          "name": "GPT-OSS 120B (Secondary for High-Level Design)"
        }
      }
    }
  },
  "agent": {
    "sisyphus": {
      "model": "reallms/Qwen3-Coder-Next"
    },
    "title": {
      "model": "reallms/Qwen3-Coder-Next"
    }
  },
  "model": "reallms/Qwen3-Coder-Next",
  "small_model": "reallms/Qwen3-Coder-Next"
}
